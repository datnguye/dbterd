//Tables (based on the selection criteria)
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.customers" {
  "customer_id" "text" [note: "The unique key of the orders mart."]
  "customer_name" "text" [note: "Customers' full name."]
  "count_lifetime_orders" "number" [note: "Total number of orders a customer has ever placed."]
  "first_ordered_at" "timestamp_ntz" [note: "The timestamp when a customer placed their first order."]
  "last_ordered_at" "timestamp_ntz" [note: "The timestamp of a customer's most recent order."]
  "lifetime_spend_pretax" "number" [note: "The sum of all the pre-tax subtotals of every order a customer has placed."]
  "lifetime_tax_paid" "number" [note: "The sum of all the tax portion of every order a customer has placed."]
  "lifetime_spend" "number" [note: "The sum of all the order totals (including tax) that a customer has ever placed."]
  "customer_type" "text" [note: "Options are 'new' or 'returning', indicating if a customer has ordered more than once or has only placed their first order to date."]

  Note: "Customer overview data mart, offering key details for each unique customer. One row per customer."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.dim_customer_segment" {
  "customer_id" "text" [note: "The foreign key to the customer."]
  "segment_code" "text" [note: "The customer segment \u2014 NEW, REGULAR, or VIP."]
  "lifetime_order_count" "number" [note: "Total number of orders placed by the customer."]

  Note: "Customer dimension with segment classification. One row per customer per segment code (composite grain)."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.fct_customer_segment_orders" {
  "order_id" "text" [note: "The unique key for each order."]
  "customer_id" "text" [note: "Part of the composite FK to dim_customer_segment."]
  "segment_code" "text" [note: "Part of the composite FK to dim_customer_segment."]
  "ordered_at" "timestamp_ntz" [note: "The date the order was placed."]
  "order_total" "number" [note: "The total order amount in USD including tax."]

  Note: "Fact table joining orders to their customer segment at time of order. One row per order."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.locations" {
  "location_id" "text" [note: "The unique key of the locations mart."]
  "location_name" "text" [note: "The name of the location."]
  "tax_rate" "float" [note: "The tax rate for the location."]
  "opened_date" "timestamp_ntz" [note: "The date the location opened."]

  Note: "Location overview data mart. One row per location."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.metricflow_time_spine" {
  "date_day" "date"

  Note: "Time spine table for MetricFlow, one row per day."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.order_items" {
  "order_item_id" "text"
  "order_id" "text"
  "product_id" "text"
  "ordered_at" "timestamp_ntz"
  "product_name" "text"
  "product_price" "number"
  "is_food_item" "boolean"
  "is_drink_item" "boolean"
  "supply_cost" "number"

  Note: ""
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.orders" {
  "order_id" "text" [note: "The unique key of the orders mart."]
  "customer_id" "text" [note: "The foreign key relating to the customer who placed the order."]
  "location_id" "text" [note: "The foreign key relating to the location where the order was placed."]
  "order_total" "number" [note: "The total amount of the order in USD including tax."]
  "ordered_at" "timestamp_ntz" [note: "The timestamp the order was placed at."]
  "subtotal_cents" "number" [note: "The pre-tax subtotal of the order in cents."]
  "tax_paid_cents" "number" [note: "The tax portion of the order in cents."]
  "order_total_cents" "number" [note: "The total amount of the order in cents including tax."]
  "subtotal" "number" [note: "The pre-tax subtotal of the order in USD."]
  "tax_paid" "number" [note: "The tax portion of the order in USD."]
  "order_cost" "number" [note: "The sum of supply expenses to fulfill the order."]
  "order_items_subtotal" "number" [note: "The sum of product prices for all items in the order."]
  "count_order_items" "number" [note: "The number of items in the order."]
  "count_food_items" "number" [note: "The number of food items in the order."]
  "count_drink_items" "number" [note: "The number of drink items in the order."]
  "is_food_order" "boolean" [note: "A boolean indicating if this order included any food items."]
  "is_drink_order" "boolean" [note: "A boolean indicating if this order included any drink items."]
  "customer_order_number" "number" [note: "The sequential order number for this customer (1 = first order)."]

  Note: "Order overview data mart, offering key details for each order inlcluding if it's a customer's first order and a food vs. drink item breakdown. One row per order."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.products" {
  "product_id" "text"
  "product_name" "text"
  "product_type" "text"
  "product_description" "text"
  "product_price" "number"
  "is_food_item" "boolean"
  "is_drink_item" "boolean"

  Note: ""
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.stg_customers" {
  "customer_id" "text" [note: "The unique key for each customer."]
  "customer_name" "text"

  Note: "Customer data with basic cleaning and transformation applied, one row per customer."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.stg_locations" {
  "location_id" "text" [note: "The unique key for each location."]
  "location_name" "text"
  "tax_rate" "float"
  "opened_date" "timestamp_ntz"

  Note: "List of open locations with basic cleaning and transformation applied, one row per location."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.stg_order_items" {
  "order_item_id" "text" [note: "The unique key for each order item."]
  "order_id" "text" [note: "The corresponding order each order item belongs to"]
  "product_id" "text"

  Note: "Individual food and drink items that make up our orders, one row per item."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.stg_orders" {
  "order_id" "text" [note: "The unique key for each order."]
  "location_id" "text"
  "customer_id" "text"
  "subtotal_cents" "number"
  "tax_paid_cents" "number"
  "order_total_cents" "number"
  "subtotal" "number"
  "tax_paid" "number"
  "order_total" "number"
  "ordered_at" "timestamp_ntz"

  Note: "Order data with basic cleaning and transformation applied, one row per order."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.stg_products" {
  "product_id" "text" [note: "The unique key for each product."]
  "product_name" "text"
  "product_type" "text"
  "product_description" "text"
  "product_price" "number"
  "is_food_item" "boolean"
  "is_drink_item" "boolean"

  Note: "Product (food and drink items that can be ordered) data with basic cleaning and transformation applied, one row per product."
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.stg_supplies" {
  "supply_uuid" "text" [note: "The unique key of our supplies per cost."]
  "supply_id" "text"
  "product_id" "text"
  "supply_name" "text"
  "supply_cost" "number"
  "is_perishable_supply" "boolean"

  Note: "List of our supply expenses data with basic cleaning and transformation applied.\nOne row per supply cost, not per supply. As supply costs fluctuate they receive a new row with a new UUID. Thus there can be multiple rows per supply_id.\n"
}
//--configured at schema: shaman.dummy
Table "model.jaffle_shop.supplies" {
  "supply_uuid" "text"
  "supply_id" "text"
  "product_id" "text"
  "supply_name" "text"
  "supply_cost" "number"
  "is_perishable_supply" "boolean"

  Note: ""
}
//Refs (based on the DBT Relationship Tests)
Ref: "model.jaffle_shop.order_items"."order_id" > "model.jaffle_shop.orders"."order_id"
Ref: "model.jaffle_shop.orders"."customer_id" > "model.jaffle_shop.stg_customers"."customer_id"
Ref: "model.jaffle_shop.stg_order_items"."order_id" > "model.jaffle_shop.stg_orders"."order_id"
